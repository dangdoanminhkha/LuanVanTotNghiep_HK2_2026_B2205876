# ===========================================
# Hướng dẫn: Tạo file .env riêng cho mỗi service
# ===========================================

# 🔧 BACKEND (.env in backend/)
# ==========================
# PORT=5000
# DB_HOST=localhost
# DB_USER=root
# DB_PASSWORD=admin123
# DB_NAME=shoestore
# JWT_SECRET=your_jwt_secret_key
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_USER=your_email@gmail.com
# SMTP_PASS=your_app_password
# SMTP_FROM="Shoestore <no-reply@shoestore.local>"
# SMTP_SECURE=true
# FRONTEND_URL=http://localhost:5173
# BACKEND_URL=http://localhost:5000 (or ngrok URL in dev)
# GOOGLE_CLIENT_ID=your_google_client_id
# GOOGLE_CLIENT_SECRET=your_google_client_secret
# VNPAY_TMN_CODE=3ARR1DJS
# VNPAY_HASH_SECRET=0W74BMW3QDC0WD9FXIO1G6L0GHYFF6LU
# VNPAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
# VNPAY_RETURN_URL=your_backend_url/payment/vnpay-return
# VNPAY_IPN_URL=your_backend_url/api/payment/vnpay/ipn
# PAYMENT_DEMO_MODE=false (sandbox thật)
# PAYMENT_DEMO_MODE=true (fallback demo nội bộ)
# ORDER_HOLD_MINUTES=15

# 🎨 FRONTEND (.env in frontend/)
# ================================
# VITE_API_URL=http://localhost:5000
# VITE_GOOGLE_CLIENT_ID=your_google_client_id

# 🤖 ML SERVICE (.env in ml/)
# ============================
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=admin123
# DB_NAME=shoestore
# ML_PORT=5001
# CF_WEIGHT=0.7
# CBF_WEIGHT=0.3
# SVD_COMPONENTS=50

# ===========================================
# Lưu ý: Mỗi folder con có file .env.example
# Copy và điền giá trị:
# cp backend/.env.example backend/.env
# cp frontend/.env.example frontend/.env
# cp ml/.env.example ml/.env
# ===========================================
