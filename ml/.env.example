# Cấu hình ML Service
# Copy file này thành .env và điền giá trị thực

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=shoestore

# Flask API port
ML_PORT=5001

# Trọng số Hybrid (cf_weight + cbf_weight phải = 1.0)
CF_WEIGHT=0.7
CBF_WEIGHT=0.3

# Số chiều ẩn TruncatedSVD
SVD_COMPONENTS=50
