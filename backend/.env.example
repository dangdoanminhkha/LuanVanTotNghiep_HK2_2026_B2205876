# Server
PORT=5000

# Database (Railway MySQL auto-generates these)
DB_HOST=your-railway-mysql-host
DB_USER=root
DB_PASSWORD=your-railway-mysql-password
DB_NAME=railway
DB_PORT=3306

# JWT
JWT_SECRET=your-random-secret-key-min-32-characters

# SMTP Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="ShoeStore <no-reply@shoestore.com>"
SMTP_SECURE=true

# Frontend URL (Vercel URL after deploy)
FRONTEND_URL=https://your-app.vercel.app

# Google OAuth2
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# VNPay Configuration (Sandbox)
# Merchant test info (provided):
# - vnp_TmnCode: 3ARR1DJS
# - vnp_HashSecret: 0W74BMW3QDC0WD9FXIO1G6L0GHYFF6LU
VNPAY_TMN_CODE=3ARR1DJS
VNPAY_HASH_SECRET=0W74BMW3QDC0WD9FXIO1G6L0GHYFF6LU
VNPAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=https://your-app.vercel.app/payment/vnpay-return
VNPAY_IPN_URL=https://your-backend-domain/api/payment/vnpay/ipn

# Payment mode switch
# - false: dùng VNPay sandbox thật
# - true: dùng trang demo nội bộ (/payment/demo)
PAYMENT_DEMO_MODE=false

# Order hold configuration (minutes before unpaid orders auto-cancel)
ORDER_HOLD_MINUTES=15

